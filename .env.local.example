# Copy this file to `.env.local` and fill in your Supabase project values.
# Find these in your Supabase dashboard → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Optional: only needed for the daily expiry-email Edge Function ---
# Service role key (KEEP SECRET — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Resend API key for sending expiry digests (https://resend.com)
RESEND_API_KEY=your-resend-key
# Address the digest is sent from (must be a verified Resend sender)
EXPIRY_EMAIL_FROM=Trove <trove@yourdomain.com>

# --- Optional: on-device Gemma 4 nutrition-label parsing ---
# WITHOUT this, label scanning still works using the built-in heuristic parser.
# WITH it, the OCR'd text is structured by Gemma 4 E2B running fully in the
# browser via WebGPU (no server, no key, offline after first download ~500MB).
# Point it at a LiteRT/.task web bundle, e.g. from:
#   https://huggingface.co/litert-community/gemma-4-E2B-it-litert-lm
# NEXT_PUBLIC_GEMMA_MODEL_URL=https://your-host/gemma-4-e2b-it-int4-web.task

# --- Optional: web push notifications (daily expiry/payment reminders) ---
# Generate a key pair once with:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com
# A random string; Vercel Cron sends it as a bearer token to /api/push/send.
CRON_SECRET=any-long-random-string
# (Also requires SUPABASE_SERVICE_ROLE_KEY above for the send job.)
